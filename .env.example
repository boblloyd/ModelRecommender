# Copy to .env and fill in real values. Never commit .env to SCM.

# Civitai API (free key: civitai.com → Account → Settings → API Keys)
CIVITAI_API_TOKEN=your_civitai_token_here

# HuggingFace API (optional, for Phase 3 HF crawler)
HF_TOKEN=your_huggingface_token_here

# PostgreSQL connection string
# In k8s this is injected from the Secret; in local dev match docker-compose
DATABASE_URL=postgresql://recommender:recommender@localhost:5432/model_catalog

# Ollama — runs on the host, not in k8s (GPU access)
# In k8s set this to your node's LAN IP, e.g. http://192.168.1.x:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_PRIMARY=dolphin3.0-llama3.1:8b
OLLAMA_MODEL_FALLBACK=gemma3:12b

# Crawler tuning
DEFAULT_BASE_MODEL=Flux.1 D
CRAWL_PAGE_SIZE=100
RATE_LIMIT_BACKOFF_START=2
RATE_LIMIT_BACKOFF_MAX=30

# Kubernetes (used by API when dispatching crawler Jobs)
K8S_NAMESPACE=model-recommender
CRAWLER_IMAGE=model-recommender:latest
